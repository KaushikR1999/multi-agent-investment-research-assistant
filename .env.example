# Backend
APP_ENV=local
LOG_LEVEL=INFO

# LLM provider: openai or gemini
LLM_PROVIDER=gemini
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
LLM_TIMEOUT_SECONDS=60
LLM_OUTPUT_TOKEN_LIMIT=4096
SYNTHESIS_MAX_CLAIMS_PER_OUTPUT=6
SYNTHESIS_MAX_EVIDENCE_ITEMS=40

# News provider
NEWS_API_KEY=

# Frontend
BACKEND_URL=http://localhost:8000
